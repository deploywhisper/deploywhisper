exports[`ScoreRing > renders light and dark tracks 1`] = `"<div><span aria-label="Risk score: 78 out of 100" class="dw-score-ring" role="img" style="height:76px;width:76px"><svg aria-hidden="true" height="76" width="76"><defs><linearGradient id="R1-score-gradient" x1="0%" x2="100%" y1="0%" y2="100%"><stop offset="0%" stop-color="#FF8A4C"></stop><stop offset="55%" stop-color="#F2511F"></stop><stop offset="100%" stop-color="#E03D0A"></stop></linearGradient></defs><circle cx="38" cy="38" fill="none" r="34.5" stroke="#EEF0F3" stroke-width="7"></circle><circle class="dw-score-ring-progress" cx="38" cy="38" fill="none" r="34.5" stroke="url(#R1-score-gradient)" stroke-dasharray="216.76989309769573" stroke-dashoffset="47.689376481493056" stroke-linecap="round" stroke-width="7"></circle></svg><span class="dw-score-ring-label"><span class="dw-score-ring-score" style="font-size:22.8px">78</span><span class="dw-score-ring-total">/100</span></span></span><span aria-label="Risk score: 42 out of 100" class="dw-score-ring dw-score-ring-dark" role="img" style="height:72px;width:72px"><svg aria-hidden="true" height="72" width="72"><defs><linearGradient id="R2-score-gradient" x1="0%" x2="100%" y1="0%" y2="100%"><stop offset="0%" stop-color="#FF8A4C"></stop><stop offset="55%" stop-color="#F2511F"></stop><stop offset="100%" stop-color="#E03D0A"></stop></linearGradient></defs><circle cx="36" cy="36" fill="none" r="32.5" stroke="#2C303C" stroke-width="7"></circle><circle class="dw-score-ring-progress" cx="36" cy="36" fill="none" r="32.5" stroke="url(#R2-score-gradient)" stroke-dasharray="204.20352248333654" stroke-dashoffset="118.4380430403352" stroke-linecap="round" stroke-width="7"></circle></svg><span class="dw-score-ring-label"><span class="dw-score-ring-score" style="font-size:21.599999999999998px">42</span><span class="dw-score-ring-total">/100</span></span></span></div>"`;

exports[`SegmentedTabs > renders accessible tabs with count pill 1`] = `"<div aria-label="Sections" class="dw-tabs" role="tablist"><button aria-selected="false" class="dw-tab" role="tab" type="button">Overview</button><button aria-selected="true" class="dw-tab dw-tab-active" role="tab" type="button">Findings<span class="dw-tab-count">3</span></button><button aria-selected="false" class="dw-tab" role="tab" type="button">Audit</button></div>"`;

